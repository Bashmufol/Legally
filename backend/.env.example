GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# SerpApi (official web search + contact discovery for all jurisdictions)
SERPAPI_ENABLED=true
SERPAPI_API_KEY=your_serpapi_api_key

# =============================================================================
# PostgreSQL — Option A (Spring Boot JDBC → Cloud SQL from Firebase SQL Connect)
# =============================================================================
#
# MODE 1 — Local Docker (default)
DATABASE_MODE=local
DATABASE_URL=jdbc:postgresql://localhost:5432/legally
DATABASE_USERNAME=legally
DATABASE_PASSWORD=legally
#
# MODE 2 — Cloud SQL via socket factory (production on GCP / Render with GCP access)
# Use after Firebase SQL Connect finishes provisioning your instance.
# DATABASE_MODE=cloud-sql
# CLOUD_SQL_INSTANCE_CONNECTION_NAME=your-project-id:us-east4:legally-7f34d-instance
# CLOUD_SQL_DATABASE_NAME=legally-7f34d-database
# DATABASE_USERNAME=postgres
# DATABASE_PASSWORD=your_cloud_sql_password
# SPRING_PROFILES_ACTIVE=cloudsql
#
# MODE 3 — Cloud SQL via Auth Proxy on your laptop (local dev against Firebase DB)
# 1) Run: cloud-sql-proxy your-project-id:us-east4:legally-7f34d-instance
# 2) Set:
# DATABASE_MODE=direct
# DATABASE_URL=jdbc:postgresql://127.0.0.1:5432/legally-7f34d-database
# DATABASE_USERNAME=postgres
# DATABASE_PASSWORD=your_cloud_sql_password

# --- Local defaults ---
DATABASE_MODE=local
DATABASE_URL=jdbc:postgresql://localhost:5432/legally
DATABASE_USERNAME=legally
DATABASE_PASSWORD=legally

# Firebase Admin (Auth verification + Storage) — unchanged
FIREBASE_ENABLED=true
FIREBASE_CREDENTIALS_PATH=./firebase-service-account.json
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
FIREBASE_REQUIRE_AUTH=true
FIREBASE_ANONYMOUS_ONLY=true

CORS_ALLOWED_ORIGINS=http://localhost:5173
SERVER_PORT=8080
