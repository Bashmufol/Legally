# --- Local dev with Cloud Run backend (recommended; avoids CORS) ---
VITE_USE_API_PROXY=true
VITE_PROXY_TARGET=https://your-service-xxxxx.us-east4.run.app
VITE_API_URL=

# --- Local dev with backend on your machine ---
# VITE_USE_API_PROXY=false
# VITE_API_URL=http://localhost:8080

# --- Vercel / production build (set in Vercel dashboard; no proxy) ---
# VITE_USE_API_PROXY=false
# VITE_API_URL=https://your-service-xxxxx.us-east4.run.app
# Also add your Vercel URL to Cloud Run CORS_ALLOWED_ORIGINS

# Firebase Web SDK (enable Anonymous sign-in in Firebase Console)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
